---
import Layout from '../layouts/Layout.astro';
---

<Layout>

  <!-- HERO -->
  <section class="bg-white">
    <div class="grid max-w-7xl px-4 py-12 mx-auto lg:grid-cols-12 gap-8">
      <div class="lg:col-span-5 text-center lg:text-left">
        <h1 class="text-4xl md:text-5xl xl:text-6xl font-extrabold text-gray-900 mb-4">
          Accede a una beca y transforma tu futuro
        </h1>
        <p class="text-gray-500 text-lg mb-6">
          Apoyamos a jóvenes de áreas rurales en Guatemala para acceder a educación superior y oportunidades reales.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <a href="#" class="px-6 py-3 text-white bg-primary-700 rounded-lg hover:bg-primary-800">
            Aplicar a beca
          </a>
          <a href="#" class="px-6 py-3 border border-gray-300 rounded-lg hover:bg-gray-100">
            Conocer más
          </a>
        </div>
      </div>

      <div class="lg:col-span-7">
        <img class="w-full rounded-lg" src="https://get.pxhere.com/photo/person-people-play-boy-child-education-laughing-kids-children-infant-toddler-school-indian-ahmedabad-1104035.jpg" />
      </div>
    </div>
  </section>


  <!-- IMPACTO -->
  <section class="bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 py-16">
      <div class="max-w-3xl">
        <h2 class="text-4xl font-extrabold text-gray-900 mb-4">Nuestro impacto</h2>
        <p class="text-gray-600 text-lg">
          Durante más de 20 años hemos brindado acceso a educación superior a jóvenes en comunidades rurales, generando oportunidades reales de crecimiento profesional y desarrollo personal.
        </p>
      </div>
    </div>
  </section>


  <!-- STATS -->
  <section class="bg-white">
    <div class="max-w-5xl mx-auto py-16 text-center grid grid-cols-1 sm:grid-cols-3 gap-8">
      <div>
        <p class="text-4xl font-extrabold text-gray-900">+1000</p>
        <p class="text-gray-500">Jóvenes becados</p>
      </div>
      <div>
        <p class="text-4xl font-extrabold text-gray-900">+3</p>
        <p class="text-gray-500">Departamentos</p>
      </div>
      <div>
        <p class="text-4xl font-extrabold text-gray-900">+20</p>
        <p class="text-gray-500">Años de impacto</p>
      </div>
    </div>
  </section>


  <!-- TESTIMONIOS -->
  <section class="bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 py-16">
      <h2 class="text-4xl font-extrabold text-center text-gray-900 mb-12">
        Historias que inspiran
      </h2>

      <div class="grid md:grid-cols-3 gap-8">
        
        <div class="bg-white p-6 rounded-lg shadow">
          <p class="text-gray-600 mb-4">
            “Gracias a la beca pude continuar mis estudios y ahora soy profesional.”
          </p>
          <h3 class="font-bold text-gray-900">María López</h3>
        </div>

        <div class="bg-white p-6 rounded-lg shadow">
          <p class="text-gray-600 mb-4">
            “El apoyo cambió completamente mi vida y la de mi familia.”
          </p>
          <h3 class="font-bold text-gray-900">Juan Pérez</h3>
        </div>

        <div class="bg-white p-6 rounded-lg shadow">
          <p class="text-gray-600 mb-4">
            “Hoy tengo oportunidades que antes parecían imposibles.”
          </p>
          <h3 class="font-bold text-gray-900">Ana García</h3>
        </div>

      </div>
    </div>
  </section>


  <!-- QUIÉNES SOMOS (PREVIEW) -->
  <section class="bg-white">
    <div class="max-w-7xl mx-auto px-4 py-16">
      <div class="max-w-3xl">
        <h2 class="text-4xl font-extrabold text-gray-900 mb-4">¿Quiénes somos?</h2>
        <p class="text-gray-600 mb-6">
          Somos una fundación comprometida con el desarrollo educativo en Guatemala, enfocada en brindar oportunidades a jóvenes con alto potencial.
        </p>

        <a href="#" class="text-primary-700 font-medium hover:underline">
          Conocer más →
        </a>
      </div>
    </div>
  </section>


  <!-- PROGRAMAS DESTACADOS -->
  <section class="bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 py-16">
      <h2 class="text-4xl font-extrabold text-gray-900 mb-12 text-center">
        Cómo puedes involucrarte
      </h2>

      <div class="grid md:grid-cols-3 gap-8">

        <div class="bg-white p-6 rounded-lg shadow">
          <h3 class="text-xl font-bold mb-2">Apadrinamiento</h3>
          <p class="text-gray-600 mb-4">
            Apoya directamente la educación de un estudiante.
          </p>
          <a href="#" class="text-primary-700 font-medium">Apadrinar →</a>
        </div>

        <div class="bg-white p-6 rounded-lg shadow">
          <h3 class="text-xl font-bold mb-2">Donaciones</h3>
          <p class="text-gray-600 mb-4">
            Contribuye con recursos para nuestras iniciativas.
          </p>
          <a href="#" class="text-primary-700 font-medium">Donar →</a>
        </div>

        <div class="bg-white p-6 rounded-lg shadow">
          <h3 class="text-xl font-bold mb-2">Inversión social</h3>
          <p class="text-gray-600 mb-4">
            Impulsa proyectos de emprendimiento juvenil.
          </p>
          <a href="#" class="text-primary-700 font-medium">Invertir →</a>
        </div>

      </div>
    </div>
  </section>


  <!-- CTA FINAL -->
  <section class="bg-primary-700">
    <div class="max-w-5xl mx-auto text-center px-4 py-16">
      <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-4">
        Sé parte del cambio
      </h2>
      <p class="text-white mb-6">
        Tu apoyo puede transformar la vida de un joven.
      </p>

      <a href="#" class="px-6 py-3 bg-white text-primary-700 font-medium rounded-lg hover:bg-gray-100">
        Donar ahora
      </a>
    </div>
  </section>

</Layout>