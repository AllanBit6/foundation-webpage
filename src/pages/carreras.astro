---
import Layout from "../layouts/Layout.astro";
import SectionHero from "../components/SectionHero.astro";

const carreras = [
  {
    nombre: "Administracion de Empresas",
    descripcion:
      "Formacion para liderar equipos, gestionar recursos y crear soluciones sostenibles en organizaciones.",
    duracion: "4 a 5 anos",
    oportunidadesLaborales: [
      "Administrador de empresas",
      "Coordinador de proyectos",
      "Analista administrativo",
    ],
    oportunidadesUniversitarias: [
      "Licenciatura en Administracion",
      "Especializacion en gestion empresarial",
      "Maestria en direccion de negocios",
    ],
    video: "",
  },
  {
    nombre: "Contaduria Publica y Auditoria",
    descripcion:
      "Preparacion en finanzas, control interno y analisis contable para apoyar decisiones empresariales.",
    duracion: "4 a 5 anos",
    oportunidadesLaborales: [
      "Contador general",
      "Auditor interno",
      "Analista financiero",
    ],
    oportunidadesUniversitarias: [
      "Licenciatura en Contaduria Publica",
      "Especializacion en auditoria",
      "Maestria en finanzas",
    ],
    video: "",
  },
  {
    nombre: "Ingenieria en Sistemas",
    descripcion:
      "Desarrollo de habilidades en programacion, tecnologia y resolucion de problemas digitales.",
    duracion: "4 a 5 anos",
    oportunidadesLaborales: [
      "Desarrollador de software",
      "Administrador de sistemas",
      "Analista de datos",
    ],
    oportunidadesUniversitarias: [
      "Ingenieria en Sistemas",
      "Especializacion en ciberseguridad",
      "Maestria en tecnologia",
    ],
    video: "",
  },
  {
    nombre: "Enfermeria",
    descripcion:
      "Vocacion de servicio y conocimientos clinicos para brindar atencion humana y profesional.",
    duracion: "3 a 5 anos",
    oportunidadesLaborales: [
      "Enfermero profesional",
      "Auxiliar clinico",
      "Coordinador de salud comunitaria",
    ],
    oportunidadesUniversitarias: [
      "Licenciatura en Enfermeria",
      "Especializacion en salud publica",
      "Formacion en cuidados intensivos",
    ],
    video: "",
  },
  {
    nombre: "Psicologia",
    descripcion:
      "Comprension del comportamiento humano para acompanar procesos de bienestar personal y social.",
    duracion: "5 anos",
    oportunidadesLaborales: [
      "Psicologo educativo",
      "Orientador vocacional",
      "Asistente de recursos humanos",
    ],
    oportunidadesUniversitarias: [
      "Licenciatura en Psicologia",
      "Especializacion clinica",
      "Maestria en psicologia educativa",
    ],
    video: "",
  },
  {
    nombre: "Educacion",
    descripcion:
      "Herramientas pedagogicas para formar nuevas generaciones con compromiso, creatividad y liderazgo.",
    duracion: "3 a 5 anos",
    oportunidadesLaborales: [
      "Docente",
      "Coordinador academico",
      "Facilitador de programas educativos",
    ],
    oportunidadesUniversitarias: [
      "Profesorado",
      "Licenciatura en Educacion",
      "Especializacion en pedagogia",
    ],
    video: "",
  },
];
---

<Layout>
  <SectionHero title="Carreras">
    Acompanamos a jovenes en su camino hacia una profesion con futuro, impacto y oportunidades reales.
  </SectionHero>

  <section class="bg-secondary-soft">
    <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
      <div class="mx-auto mb-10 max-w-3xl text-center">
        <span class="text-sm font-bold uppercase tracking-wide text-primary-600">
          Oferta educativa
        </span>
        <h2 class="mt-3 font-heading text-3xl font-extrabold text-primary-700 sm:text-4xl">
          Carreras que impulsan el desarrollo
        </h2>
        <p class="mt-4 text-base leading-7 text-primary-800 sm:text-lg">
          Estas son algunas de las areas profesionales que apoyamos para que cada estudiante pueda construir una trayectoria con proposito.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {carreras.map((carrera) => (
          <article class="group overflow-hidden rounded-lg border border-secondary/60 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-lg">
            <div class="aspect-[4/3] overflow-hidden bg-primary-100">
              {carrera.video ? (
                <video
                  class="h-full w-full object-cover transition duration-300 group-hover:scale-105"
                  src={carrera.video}
                  controls
                  preload="metadata"
                  aria-label={`Video de ${carrera.nombre}`}
                ></video>
              ) : (
                <div class="flex h-full w-full items-center justify-center px-6 text-center">
                  <span class="rounded-lg border border-primary-200 bg-white/80 px-4 py-3 text-sm font-semibold text-primary-700">
                    Agrega aqui el video de {carrera.nombre}
                  </span>
                </div>
              )}
            </div>

            <div class="flex min-h-52 flex-col p-6">
              <h3 class="font-heading text-xl font-bold text-primary-700">
                {carrera.nombre}
              </h3>
              <p class="mt-3 text-sm leading-6 text-primary-800 sm:text-base">
                {carrera.descripcion}
              </p>

              <div class="mt-5 rounded-lg bg-secondary-soft p-4">
                <span class="text-xs font-bold uppercase tracking-wide text-primary-600">
                  Duracion
                </span>
                <p class="mt-1 text-sm font-semibold text-primary-800">
                  {carrera.duracion}
                </p>
              </div>

              <div class="mt-5 space-y-5">
                <div>
                  <h4 class="text-sm font-bold text-primary-700">
                    Oportunidades laborales
                  </h4>
                  <ul class="mt-2 space-y-1 text-sm leading-6 text-primary-800">
                    {carrera.oportunidadesLaborales.map((oportunidad) => (
                      <li class="flex gap-2">
                        <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-primary-600"></span>
                        <span>{oportunidad}</span>
                      </li>
                    ))}
                  </ul>
                </div>

                <div>
                  <h4 class="text-sm font-bold text-primary-700">
                    Oportunidades universitarias
                  </h4>
                  <ul class="mt-2 space-y-1 text-sm leading-6 text-primary-800">
                    {carrera.oportunidadesUniversitarias.map((oportunidad) => (
                      <li class="flex gap-2">
                        <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-primary-600"></span>
                        <span>{oportunidad}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>

              <a
                href="/aplicacion"
                class="mt-6 inline-flex w-fit items-center rounded-lg bg-primary-700 px-4 py-2 text-sm font-semibold text-white transition hover:bg-primary-800 focus:outline-none focus:ring-4 focus:ring-primary-200"
              >
                Aplicar ahora
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>
