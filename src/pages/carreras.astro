---
import Layout from "../layouts/Layout.astro";
import SectionHero from "../components/SectionHero.astro";

const carreras = [
  {
    nombre: "Perito Contador Bilingue con orientacion en emprendimiento social y finanzas.",
    descripcion:
      "Forma jovenes en contabilidad, administracion, ingles, tecnologia, emprendimiento y finanzas para responder a necesidades de empresas, organizaciones y proyectos comunitarios.",
    duracion: "3 años",
    oportunidadesLaborales: [
      "Apoyo contable, administrativo o financiero en empresas, bancos, cooperativas, ONG y proyectos de emprendimiento.",
    ],
    oportunidadesUniversitarias: [
      "Base para continuar estudios en auditoria, administracion, economia, derecho, negocios o comercio internacional.",
    ],
    video: "https://res.cloudinary.com/dnhistzl2/video/upload/v1778217398/accounting_gnrtvh.mp4",
  },
  {
    nombre: "Perito en Electronica con especialidad en desarrollo de software y mantenimiento de equipos digitales.",
    descripcion:
      "Prepara estudiantes en programacion, electronica, automatizacion y mantenimiento de equipos digitales, combinando pensamiento logico con soluciones tecnologicas practicas.",
    duracion: "3 años",
    oportunidadesLaborales: [
      "Oportunidades en soporte tecnico, desarrollo de software, areas de IT, centros de datos y servicios tecnologicos.",
    ],
    oportunidadesUniversitarias: [
      "Base para estudiar sistemas, electronica, telecomunicaciones, robotica, inteligencia artificial o seguridad informatica.",
    ],
    video: "https://res.cloudinary.com/dnhistzl2/video/upload/v1778129440/Electronicas_oya8b2.mp4",
  },
  {
    nombre: "Bachillerato en Ciencias Biologicas con enfasis en medicina alternativa y enfermeria.",
    descripcion:
      "Fortalece conocimientos en ciencias de la salud, primeros auxilios, nutricion comunitaria, medicina preventiva y atencion basica para servir a comunidades rurales.",
    duracion: "2 años",
    oportunidadesLaborales: [
      "Apoyo en clinicas, centros de salud, laboratorios, programas comunitarios o iniciativas relacionadas con servicios de salud.",
    ],
    oportunidadesUniversitarias: [
      "Base para continuar en medicina, enfermeria, nutricion, odontologia, psicologia, biologia o carreras afines a la salud.",
    ],
    video: "https://res.cloudinary.com/dnhistzl2/video/upload/v1778129573/Medicina-Enfermeria_a0e9pa.mp4",
  },
  {
    nombre: "Perito en mecanica automotriz, con especializacion en administracion de talleres.",
    descripcion:
      "Forma estudiantes en mantenimiento, diagnostico y reparacion de vehiculos, con bases de administracion para gestionar talleres o proyectos propios.",
    duracion: "3 años",
    oportunidadesLaborales: [
      "Trabajo en talleres, centros de servicio, diagnostico automotriz, mantenimiento de vehiculos o emprendimientos propios.",
    ],
    oportunidadesUniversitarias: [
      "Base para estudiar mecanica automotriz, mecanica industrial, ingenieria, tecnologia o areas productivas relacionadas.",
    ],
    video: "https://res.cloudinary.com/dnhistzl2/video/upload/v1778129451/Mecanica_sn0yjk.mp4",
  },
  {
    nombre: "Bachillerato Bilingue en Ciencias y Humanidades",
    descripcion:
      "Integra ingles, ciencias, salud, tecnologia, comunicacion y formacion humana para abrir oportunidades academicas y profesionales.",
    duracion: "2 años",
    oportunidadesLaborales: [
      "Apoyo en areas administrativas, educativas, comunitarias o de servicios, segun las habilidades del estudiante.",
    ],
    oportunidadesUniversitarias: [
      "Base para continuar estudios en salud, humanidades, tecnologia, ingenieria, ciencias sociales o carreras afines.",
    ],
    video: "https://res.cloudinary.com/dnhistzl2/video/upload/v1778129575/Ciencias_Exactas_2_uaqtlk.webm",
  },
  {
    nombre: "Basico Bilingue con enfasis en emprendimiento y liderazgo comunitario.",
    descripcion:
      "Desarrolla bases academicas, ingles, tecnologia, comunicacion, trabajo en equipo y liderazgo para que los jovenes puedan avanzar hacia una carrera tecnica o diversificada.",
    duracion: "3 años",
    oportunidadesLaborales: [
      "Formacion inicial para participar en proyectos comunitarios, actividades de liderazgo y emprendimientos juveniles.",
    ],
    oportunidadesUniversitarias: [
      "Prepara al estudiante para elegir carreras tecnicas, bilingues, cientificas, tecnologicas o de emprendimiento.",
    ],
    video: "https://res.cloudinary.com/dnhistzl2/video/upload/v1778129572/Educaci%C3%B3n_Integral_xmyoqq.mp4",
  },
];
---

<Layout>
  <SectionHero title="Carreras" image="/public/images/carreras.png">
    Acompanamos a jovenes en su camino hacia una profesion con futuro, impacto y oportunidades reales.
  </SectionHero>

  <section class="bg-secondary-soft">
    <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
      <div class="mx-auto mb-10 max-w-3xl text-center">
        <span class="text-sm font-bold uppercase tracking-wide text-primary-600">
          Oferta educativa
        </span>
        <h2 class="mt-3 font-heading text-3xl font-extrabold text-primary-700 sm:text-4xl">
          Carreras que impulsan el desarrollo
        </h2>
        <p class="mt-4 text-base leading-7 text-primary-800 sm:text-lg">
          Estas son algunas de las areas profesionales que apoyamos para que cada estudiante pueda construir una trayectoria con proposito.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {carreras.map((carrera) => (
          <article class="group overflow-hidden rounded-lg border border-secondary/60 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-lg">
            <div class="aspect-4/3 overflow-hidden bg-primary-100">
              {carrera.video ? (
                <video
                  class="h-full w-full object-cover transition duration-300 group-hover:scale-105"
                  src={carrera.video}
                  autoplay
                  preload="metadata"
                  loop
                  aria-label={`Video de ${carrera.nombre}`}
                ></video>
              ) : (
                <div class="flex h-full w-full items-center justify-center px-6 text-center">
                  <span class="rounded-lg border border-primary-200 bg-white/80 px-4 py-3 text-sm font-semibold text-primary-700">
                    Agrega aqui el video de {carrera.nombre}
                  </span>
                </div>
              )}
            </div>

            <div class="flex min-h-52 flex-col p-6">
              <h3 class="font-heading text-xl font-bold text-primary-700">
                {carrera.nombre}
              </h3>
              <p class="mt-3 text-sm leading-6 text-primary-800 sm:text-base">
                {carrera.descripcion}
              </p>

              <div class="mt-5 rounded-lg bg-secondary-soft p-4">
                <span class="text-xs font-bold uppercase tracking-wide text-primary-600">
                  Duracion
                </span>
                <p class="mt-1 text-sm font-semibold text-primary-800">
                  {carrera.duracion}
                </p>
              </div>

              <div class="mt-5 space-y-5">
                <div>
                  <h4 class="text-sm font-bold text-primary-700">
                    Oportunidades laborales
                  </h4>
                  <ul class="mt-2 space-y-1 text-sm leading-6 text-primary-800">
                    {carrera.oportunidadesLaborales.map((oportunidad) => (
                      <li class="flex gap-2">
                        <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-primary-600"></span>
                        <span>{oportunidad}</span>
                      </li>
                    ))}
                  </ul>
                </div>

                <div>
                  <h4 class="text-sm font-bold text-primary-700">
                    Oportunidades Educativas
                  </h4>
                  <ul class="mt-2 space-y-1 text-sm leading-6 text-primary-800">
                    {carrera.oportunidadesUniversitarias.map((oportunidad) => (
                      <li class="flex gap-2">
                        <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-primary-600"></span>
                        <span>{oportunidad}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>

              <a
                href="/aplicacion"
                class="mt-6 inline-flex w-fit items-center rounded-lg bg-primary-700 px-4 py-2 text-sm font-semibold text-white transition hover:bg-primary-800 focus:outline-none focus:ring-4 focus:ring-primary-200"
              >
                Aplicar ahora
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>
