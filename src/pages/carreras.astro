---
import Layout from "../layouts/Layout.astro";
import SectionHero from "../components/SectionHero.astro";

const carreras = [
  {
    nombre: "Perito Contador Bilingüe con orientación en emprendimiento social y finanzas.",
    descripcion:
      "Forma jóvenes en contabilidad, administración, inglés, tecnología, emprendimiento y finanzas para responder a necesidades de empresas, organizaciones y proyectos comunitarios.",
    duracion: "3 años",
    oportunidadesLaborales: [
      "Apoyo contable, administrativo o financiero en empresas, bancos, cooperativas, ONG y proyectos de emprendimiento.",
    ],
    oportunidadesUniversitarias: [
      "Base para continuar estudios en auditoría, administración, economía, derecho, negocios o comercio internacional.",
    ],
    video: "https://res.cloudinary.com/dnhistzl2/video/upload/q_auto/f_auto/v1778692155/Accounting_Gnrtvh_ly7dy8.mp4",
  },
  {
    nombre: "Perito en Electrónica con especialidad en desarrollo de software y mantenimiento de equipos digitales.",
    descripcion:
      "Prepara estudiantes en programación, electrónica, automatización y mantenimiento de equipos digitales, combinando pensamiento lógico con soluciones tecnológicas prácticas.",
    duracion: "3 años",
    oportunidadesLaborales: [
      "Oportunidades en soporte técnico, desarrollo de software, áreas de IT, centros de datos y servicios tecnológicos.",
    ],
    oportunidadesUniversitarias: [
      "Base para estudiar sistemas, electrónica, telecomunicaciones, robotica, inteligencia artificial o seguridad informática.",
    ],
    video: "https://res.cloudinary.com/dnhistzl2/video/upload/q_auto/f_auto/v1778692159/Electronicas_Oya8b2-00.00.00.000-00.00.20.301_zsqim5.mp4",
  },
  {
    nombre: "Bachillerato en Ciencias Biologicas con enfasis en medicina alternativa y enfermería.",
    descripcion:
      "Fortalece conocimientos en ciencias de la salud, primeros auxilios, nutrición comunitaria, medicina preventiva y atención básica para servir a comunidades rurales.",
    duracion: "2 años",
    oportunidadesLaborales: [
      "Apoyo en clinicas, centros de salud, laboratorios, programas comunitarios o iniciativas relacionadas con servicios de salud.",
    ],
    oportunidadesUniversitarias: [
      "Base para continuar en medicina, enfermería, nutrición, odontología, psicología, biología o carreras afines a la salud.",
    ],
    video: "https://res.cloudinary.com/dnhistzl2/video/upload/q_auto/f_auto/v1778692212/Medicina-Enfermeria_A0e9pa-00.00.02.417-00.01.06.998_ipdw6i.mp4",
  },
  {
    nombre: "Perito en mecánica automotriz, con especialización en administración de talleres.",
    descripcion:
      "Forma estudiantes en mantenimiento, diagnóstico y reparación de vehículos, con bases de administración para gestionar talleres o proyectos propios.",
    duracion: "3 años",
    oportunidadesLaborales: [
      "Trabajo en talleres, centros de servicio, diagnóstico automotriz, mantenimiento de vehículos o emprendimientos propios.",
    ],
    oportunidadesUniversitarias: [
      "Base para estudiar mecanica automotriz, mecánica industrial, ingeniería, tecnología o áreas productivas relacionadas.",
    ],
    video: "https://res.cloudinary.com/dnhistzl2/video/upload/q_auto/f_auto/v1778692287/Mecanica_Sn0yjk_oi7adr.mp4",
  },
  {
    nombre: "Bachillerato Bilingüe en Ciencias y Humanidades",
    descripcion:
      "Integra inglés, ciencias, salud, tecnología, comunicación y formación humana para abrir oportunidades académicas y profesionales.",
    duracion: "2 años",
    oportunidadesLaborales: [
      "Apoyo en áreas administrativas, educativas, comunitarias o de servicios, según las habilidades del estudiante.",
    ],
    oportunidadesUniversitarias: [
      "Base para continuar estudios en salud, humanidades, tecnología, ingeniería, ciencias sociales o carreras afines.",
    ],
    video: "https://res.cloudinary.com/dnhistzl2/video/upload/q_auto/f_auto/v1778692240/Ciencias_Exactas_2_Uaqtlk-00.00.00.000-00.00.46.523_nh1d14.mp4",
  },
  {
    nombre: "Básico Bilingüe con énfasis en emprendimiento y liderazgo comunitario.",
    descripcion:
      "Desarrolla bases académicas, inglés, tecnología, comunicación, trabajo en equipo y liderazgo para que los jóvenes puedan avanzar hacia una carrera técnica o diversificada.",
    duracion: "3 años",
    oportunidadesLaborales: [
      "Formación inicial para participar en proyectos comunitarios, actividades de liderazgo y emprendimientos juveniles.",
    ],
    oportunidadesUniversitarias: [
      "Prepara al estudiante para elegir carreras técnicas, bilingües, científicas, tecnológicas o de emprendimiento.",
    ],
    video: "https://res.cloudinary.com/dnhistzl2/video/upload/q_auto/f_auto/v1778692340/Educaci%C3%B3n_Integral_Xmyoqq-00.00.04.431-00.00.24.939_axkio2.mp4",
  },
];
---

<Layout>
  <SectionHero title="Carreras" image="/public/images/carreras.png">
    Acompanamos a jovenes en su camino hacia una profesion con futuro, impacto y oportunidades reales.
  </SectionHero>

  <section class="bg-secondary-soft">
    <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
      <div class="mx-auto mb-10 max-w-3xl text-center">
        <span class="animate pop-strong text-sm font-bold uppercase tracking-wide text-primary-600">
          Oferta educativa
        </span>
        <h2 class="animate fade-up mt-3 font-heading text-3xl font-extrabold text-primary-700 sm:text-4xl">
          Carreras que impulsan el desarrollo
        </h2>
        <p class="animate fade-left mt-4 text-base leading-7 text-primary-800 sm:text-lg">
          Estas son algunas de las areas profesionales que apoyamos para que cada estudiante pueda construir una trayectoria con propósito.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {carreras.map((carrera) => (
          <article class="group overflow-hidden rounded-lg border border-secondary/60 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-lg">
            <div class="animate pop-strong delay-500 aspect-4/3 overflow-hidden bg-primary-100">
              {carrera.video ? (
                <video
                  class="h-full w-full object-cover transition duration-300 group-hover:scale-105"
                  src={carrera.video}
                  autoplay
                  preload="metadata"
                  loop
                  aria-label={`Video de ${carrera.nombre}`}
                ></video>
              ) : (
                <div class="flex h-full w-full items-center justify-center px-6 text-center">
                  <span class="rounded-lg border border-primary-200 bg-white/80 px-4 py-3 text-sm font-semibold text-primary-700">
                    Agrega aqui el video de {carrera.nombre}
                  </span>
                </div>
              )}
            </div>

            <div class="flex min-h-52 flex-col p-6">
              <h3 class="animate rotate-in font-heading text-xl font-bold text-primary-700">
                {carrera.nombre}
              </h3>
              <p class="animte fade-down mt-3 text-sm leading-6 text-primary-800 sm:text-base">
                {carrera.descripcion}
              </p>

              <div class="animate pop mt-5 rounded-lg bg-secondary-soft p-4">
                <span class="text-xs font-bold uppercase tracking-wide text-primary-600">
                  Duracion
                </span>
                <p class="mt-1 text-sm font-semibold text-primary-800">
                  {carrera.duracion}
                </p>
              </div>

              <div class="mt-5 space-y-5">
                <div>
                  <h4 class="text-sm font-bold text-primary-700">
                    Oportunidades laborales
                  </h4>
                  <ul class="mt-2 space-y-1 text-sm leading-6 text-primary-800">
                    {carrera.oportunidadesLaborales.map((oportunidad) => (
                      <li class="flex gap-2">
                        <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-primary-600"></span>
                        <span>{oportunidad}</span>
                      </li>
                    ))}
                  </ul>
                </div>

                <div>
                  <h4 class="text-sm font-bold text-primary-700">
                    Oportunidades Educativas
                  </h4>
                  <ul class="mt-2 space-y-1 text-sm leading-6 text-primary-800">
                    {carrera.oportunidadesUniversitarias.map((oportunidad) => (
                      <li class="flex gap-2">
                        <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-primary-600"></span>
                        <span>{oportunidad}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>

              <a
                href="/aplicacion"
                class="animate pop-strong mt-6 inline-flex w-fit items-center rounded-lg bg-success-500 px-4 py-2 text-sm font-semibold text-white transition hover:bg-success-400 focus:outline-none focus:ring-4 focus:ring-primary-200"
              >
                Aplicar ahora
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>
