---
import Layout from '../layouts/Layout.astro';
import SectionHero from '../components/SectionHero.astro';
---

<Layout>

    <SectionHero title="Proceso de aplicación" video="https://res.cloudinary.com/dnhistzl2/video/upload/v1778127014/Aplicantes_v39btr.webm">
        Sigue los pasos para aplicar a una beca y comenzar tu camino profesional.
    </SectionHero>
       
  <!-- PASOS -->
  <section class="bg-secondary-soft">
    <div class="max-w-7xl mx-auto px-4 py-16">

      <div class="grid md:grid-cols-4 gap-8 text-center">

        <div class="space-y-3">
          <div class="text-3xl">📝</div>
          <h3 class="font-bold">Registro</h3>
          <p class="text-primary-800 text-sm">
            Completa el formulario inicial con tus datos personales.
          </p>
        </div>

        <div class="space-y-3">
          <div class="text-3xl">📄</div>
          <h3 class="font-bold">Documentación</h3>
          <p class="text-primary-800 text-sm">
            Adjunta papelería requerida (notas, DPI, etc.).
          </p>
        </div>

        <div class="space-y-3">
          <div class="text-3xl">📊</div>
          <h3 class="font-bold">Evaluación</h3>
          <p class="text-primary-800 text-sm">
            Revisamos tu perfil académico y situación socioeconómica.
          </p>
        </div>

        <div class="space-y-3">
          <div class="text-3xl">🎓</div>
          <h3 class="font-bold">Selección</h3>
          <p class="text-primary-800 text-sm">
            Te notificamos si fuiste seleccionado.
          </p>
        </div>

      </div>

    </div>
  </section>

  <!-- REQUISITOS -->
  <section class="bg-white">
    <div class="max-w-5xl mx-auto px-4 py-16">

      <h2 class="text-3xl font-extrabold text-primary-700 mb-6 text-center">
        Requisitos básicos
      </h2>

      <ul class="space-y-4 text-primary-800 max-w-2xl mx-auto">
        <li>• Ser estudiante graduado de nivel medio</li>
        <li>• Demostrar necesidad económica</li>
        <li>• Tener alto rendimiento académico</li>
        <li>• Compromiso con su comunidad</li>
      </ul>

    </div>
  </section>

  <!-- FORMULARIO (placeholder) -->
  <section id="formulario" class="bg-secondary-soft">
    <div class="max-w-3xl mx-auto px-4 py-16 text-center">

      <h2 class="text-3xl font-extrabold text-primary-700 mb-4">
        Formulario de aplicación
      </h2>

      <p class="text-primary-800 mb-8">
        Completa tu aplicación en línea.
      </p>

      <!-- Aquí luego metes tu form real -->
      <a href="#" class="px-8 py-3 bg-primary-700 text-white rounded-lg hover:bg-primary-800">
        Ir al formulario
      </a>

    </div>
  </section>

  <!-- CARRERAS -->
  <section class="bg-white">
    <div class="max-w-7xl mx-auto px-4 py-16">

      <div class="text-center max-w-3xl mx-auto mb-12">
        <h2 class="text-4xl font-extrabold text-primary-700 mb-4">
          Carreras disponibles
        </h2>
        <p class="text-primary-800">
          Conoce las opciones académicas disponibles para tu desarrollo profesional.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">

        <!-- Card -->
        <div class="bg-secondary-soft p-6 rounded-lg border border-secondary/60 hover:shadow-md transition">
          <h3 class="text-xl font-bold mb-2">Perito Contador Bilingüe</h3>
          <p class="text-sm text-primary-800 mb-2">
            <span class="font-medium">Duración:</span> 3 años
          </p>
          <p class="text-sm text-primary-800">
            <span class="font-medium">Campo laboral:</span> Contabilidad, auditoría, finanzas, comercio exterior, agente de Call Center.
          </p>
        </div>

        <div class="bg-secondary-soft p-6 rounded-lg border border-secondary/60 hover:shadow-md transition">
          <h3 class="text-xl font-bold mb-2">Perito en Electrónica y Dispositivos Móviles</h3>
          <p class="text-sm text-primary-800 mb-2">
            <span class="font-medium">Duración:</span> 3 años
          </p>
          <p class="text-sm text-primary-800">
            <span class="font-medium">Campo laboral:</span> Reparación de dispositivos móviles, soporte técnico, ventas de tecnología, desarrollo de software a medida.
        </div>

        <div class="bg-secondary-soft p-6 rounded-lg border border-secondary/60 hover:shadow-md transition">
          <h3 class="text-xl font-bold mb-2">Perito en Mecánica Automotriz</h3>
          <p class="text-sm text-primary-800 mb-2">
            <span class="font-medium">Duración:</span> 3 años
          </p>
          <p class="text-sm text-primary-800">
            <span class="font-medium">Campo laboral:</span> Talleres de reparación, concesionarios, empresas de transporte, servicio técnico.
        </div>

        <div class="bg-secondary-soft p-6 rounded-lg border border-secondary/60 hover:shadow-md transition">
          <h3 class="text-xl font-bold mb-2">Bachiller en Enfermería y Ciencias Biológicas</h3>
          <p class="text-sm text-primary-800 mb-2">
            <span class="font-medium">Duración:</span> 2 años
          </p>
          <p class="text-sm text-primary-800">
            <span class="font-medium">Campo laboral:</span> Enfermería, laboratorios clínicos, investigación biomédica, salud pública.
          </p>
        </div>


        <div class="bg-secondary-soft p-6 rounded-lg border border-secondary/60 hover:shadow-md transition">
          <h3 class="text-xl font-bold mb-2">Bachiller Bilingüe</h3>
          <p class="text-sm text-primary-800 mb-2">
            <span class="font-medium">Duración:</span> 2 años
          </p>
          <p class="text-sm text-primary-800">
            <span class="font-medium">Campo laboral:</span> Educación, traducción, turismo, comercio internacional, servicio al cliente.
          </p>
        </div>

        <div class="bg-secondary-soft p-6 rounded-lg border border-secondary/60 hover:shadow-md transition">
          <h3 class="text-xl font-bold mb-2">Educación Básica Completa</h3>
          <p class="text-sm text-primary-800 mb-2">
            <span class="font-medium">Duración:</span> 3 años
          </p>
          <p class="text-sm text-primary-800">
            <span class="font-medium">Campo laboral:</span> Para quienes no han completado su educación básica, ofrecemos apoyo para que puedan finalizar sus estudios y acceder a mejores oportunidades.
          </p>
        </div>

      </div>
      

      </div>

    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="bg-primary-700">
    <div class="max-w-5xl mx-auto text-center px-4 py-16">
      <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-4">
        Da el siguiente paso
      </h2>

      <p class="text-white mb-6">
        Tu futuro profesional empieza hoy.
      </p>

      <a href="#formulario" class="px-6 py-3 bg-white text-primary-700 font-medium rounded-lg hover:bg-primary-100">
        Aplicar ahora
      </a>
    </div>
  </section>

</Layout>
