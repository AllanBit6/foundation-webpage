---
import Layout from '../layouts/Layout.astro';
import SectionHero from '../components/SectionHero.astro';

const logros = [
  {
    titulo: "Enseñanza del Idioma Inglés",
    fecha: "----",
    descripcion:
      "Hemos entrenado en el idioma inglés, computación, matemáticas aplicadas, creatividad, emprendimiento social, hábitos y valores judeocristianos para el progreso, conservación del medio ambiente a más de 7,000 jóvenes y niños provenientes del área rural de los departamentos de Totonicapán, Chiquimula, Quetzaltenango, Sololá, Quiche y Huehuetenango..",
    imagen: "/images/ingles.jpg",
  },
  {
    titulo: "Escuela de Padres",
    fecha: "2016",
    descripcion:
      "A través de la Escuela de Padres de familia, se han capacitado a más de 3,000 padres de familia en temas de Finanzas personales, emprendimiento social, liderazgo comunitario, ética y hábitos del progreso, nutrición comunitaria, medicina alternativa, formación ciudadana y política, entre otros temas de alto interés para el desarrollo sostenible de las familias rurales..",
    imagen: "/images/20200306_092734.jpg",
  },
  {
    titulo: "Apadrinamiento",
    fecha: "----",
    descripcion:
      "En los últimos 10 años se ha apadrinado con becas a más de 6.000 estudiantes para culminar sus estudios de educación básica y bachillerato, así mismo el entrenamiento de centenas de estudiantes para aplicarse a becas en las mejores universidades locales, fundaciones guatemaltecas y en el extranjero. .",
    imagen: "/images/apadrinamiento.JPG",
  },
  {
    titulo: "Graduacion de estudiantes",
    fecha: "2022",
    descripcion:
      "Estudiantes y padres de familia celebraron la graduación de alrededor de 150 estudiantes que culminaron sus estudios de las diferentes carreras diversificadas (biología, electrónica, mecánica automotriz, perito contador y bachillerato bilingüe) en el año 2023, con la presencia de autoridades locales, familiares y amigos.",
    imagen: "/images/graduacion2023.jpg",
  },
  {
    titulo: "Graduacion de estudiantes",
    fecha: "2024",
    descripcion:
      "Se graduaron alrededor de 125 estudiantes de las diferentes carreras diversificadas (biología, electrónica, mecánica automotriz, perito contador y bachillerato bilingüe) en el año 2024, con la presencia de autoridades locales, familiares y amigos.",
    imagen: "/images/graduacion2024.JPG",
  },
  {
    titulo: "Presencia en Olimpiada Nacional de Ciencias",
    fecha: "2023",
    descripcion:
      "Dos estudiantes de las carreras de electronica y biologia participaron en la Olimpiada Nacional de Ciencias, obteniendo el 2do lugar en Química y 4to lugar en física respectivamente, compitiendo con estudiantes de todo el país.",
    imagen: "/images/olimpiadas2023.jpg",
  },
  {
    titulo: "Presencia en Olimpiada Nacional de Ciencias",
    fecha: "2023",
    descripcion:
      "Estudiante de la carrera de biología participó en la competencia obteniendo el 2do lugar en la categoría de biología, compitiendo con estudiantes de todo el país.",
    imagen: "/images/olimpiadas2024.jpg",
  },
{
    titulo: "Presencia en Olimpiada Nacional de Ciencias",
    fecha: "2018",
    descripcion:
      "Estudiantes de las diferentes carreras tuvieron el honor de participar en la ONC del año 2028 teniendo un destacado desempeño, logrando ocupar lugares a nivel regional",
    imagen: "/images/olimpiadas2018.jpg",
  },
  {
    titulo: "Reconocimiento a colaboradores",
    fecha: "2025",
    descripcion:
      "Se concedió un reconocimiento a colaboradores destacados por su compromiso y dedicación en la misión de transformar vidas a través de la educación integral, destacando su impacto positivo en la comunidad y el desarrollo sostenible.",
    imagen: "/images/reconocimiento.jpg",
  },
  {
    titulo: "Reconocimiento a Jurados Voluntarios",
    fecha: "2025",
    descripcion:
      "Se otorgó un reconocimiento a las distinguidas personas que se desempeñaron como jurados en la Feria Científica del año 2025, galardonando su destacada labor en la evaluación de proyectos científicos, su compromiso con la promoción de la ciencia y su contribución al desarrollo académico de los jóvenes participantes.",
    imagen: "/images/jurados.jpg",
  },
  {
    titulo: "Ganadores de la Feria del Emprendimiento",
    fecha: "2025",
    descripcion:
      "Se reconoce el esfuerzo de estudiantes que se prepararon durante meses para participar en la Feria del Emprendimiento del año 2025, obteniendo el primer lugar con su proyecto de emprendimiento social, destacando su innovación, impacto social y compromiso con el desarrollo sostenible.",
    imagen: "/images/emprendimiento.jpg",
  },
  {
    titulo: "Visita de Rotary Group",
    fecha: "2016",
    descripcion:
      "Miembros del grupo Rotary visitaron nuestras instalaciones para conocer de cerca el impacto de nuestros programas, interactuar con estudiantes y colaboradores, y explorar oportunidades de colaboración para fortalecer nuestra misión de transformar vidas a través de la educación integral.",
    imagen: "/images/escuela20216.jpg",
  },
  {
    titulo: "Visita de Rotary Group",
    fecha: "2023",
    descripcion:
      "Con el objetivo de brindar ayuda en cuanto a equipo de computo y práctica en el idioma inglés, miembros del grupo Rotary visitaron nuestras instalaciones para conocer de cerca el impacto de nuestros programas, interactuar con estudiantes y colaboradores y pasar un día de convivencia inolvidable.",
    imagen: "/images/rotary2023.jpg",
  }
];

logros.sort((a, b) => {
  const sinFechaA = a.fecha === "----";
  const sinFechaB = b.fecha === "----";

  if (sinFechaA && !sinFechaB) return -1;
  if (!sinFechaA && sinFechaB) return 1;
  if (sinFechaA && sinFechaB) return 0;

  return Number(b.fecha) - Number(a.fecha);
});

const videos = [
  {
    titulo: "Emprendiendo el futuro",
    youtubeId: "xjxhI5ni43k?si=BYBDRN_NeMWinYGy",
  },
  {
    titulo: "Feria Científica 2025",
    youtubeId: "eUADWwMk4l0?si=EpvLZPrXq6tae83m",
  },
  {
    titulo: "Tecnología con propósito",
   youtubeId: "s2TugOkpVSI?si=wYz7T7FrM4RaMM36",
  }, 
  {
    titulo: "Ciencias Aplicadas",
    youtubeId: "lAK_THe3z8k?si=-9y72JQLAqypoamP",
  }
];
---

<Layout>
  <SectionHero title="Logros" image="/achieves.jpg">
    A lo largo de nuestra trayectoria, hemos alcanzado hitos significativos que reflejan nuestro compromiso con la educación integral y el impacto positivo en la vida de los jóvenes guatemaltecos.
  </SectionHero>

  <section class="bg-white">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">

    <div class="mx-auto mb-10 max-w-3xl text-center">
      <span class="animate fade-left text-sm font-bold uppercase tracking-wide text-primary-600">
        Galería de logros
      </span>

      <h2 class="animate pop mt-3 font-heading text-3xl font-extrabold text-primary-700 sm:text-4xl">
        Momentos que cuentan nuestra historia
      </h2>

      <p class="animate lift mt-4 text-base leading-7 text-primary-800 sm:text-lg">
        Cada logro representa un paso adelante en nuestra misión de transformar vidas.
      </p>
    </div>


    <div class="columns-1 gap-6 sm:columns-2 lg:columns-3">

      {logros.map((logro) => (
        <article class="animate pop-strong mb-6 break-inside-avoid overflow-hidden rounded-2xl border border-secondary/60 bg-white shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-lg">

          <div class="overflow-hidden bg-primary-100">
            {logro.imagen ? (
              <img
                class="h-auto w-full object-cover transition duration-500 hover:scale-105"
                src={logro.imagen}
                alt={logro.titulo}
                loading="lazy"
              />
            ) : (
              <div class="flex h-64 items-center justify-center">
                <span class="rounded-lg border border-primary-200 bg-white/80 px-4 py-3 text-sm font-semibold text-primary-700">
                  Agrega aqui la imagen
                </span>
              </div>
            )}
          </div>

          <div class="p-6">
            <time class="text-sm font-bold uppercase tracking-wide text-primary-600">
              {logro.fecha}
            </time>

            <h3 class="mt-2 font-heading text-xl font-bold text-primary-700">
              {logro.titulo}
            </h3>

            <p class="mt-3 text-sm leading-6 text-primary-800 sm:text-base">
              {logro.descripcion}
            </p>
          </div>
        </article>
      ))}

    </div>
  </div>
</section>

  <section class="bg-secondary-soft">
    <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
      <div class="mx-auto mb-10 max-w-3xl text-center">
        <span class="animate pop-strong text-sm font-bold uppercase tracking-wide text-primary-600">
          Videos
        </span>
        <h2 class="animate pop mt-3 font-heading text-3xl font-extrabold text-primary-700 sm:text-4xl">
          Memoria Visual
        </h2>
        <p class="mt-4 text-base leading-7 text-primary-800 sm:text-lg">
          Echa un vistazo a los videos que documentan los momentos mas importantes de nuestra labor y el impacto en la vida de los jóvenes.
        </p>
      </div>

      <div class="animate zoom-fade grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {videos.map((video) => (
          <article class="animate pop-strong overflow-hidden rounded-lg border border-secondary/60 bg-white shadow-sm">
            <div class="aspect-9/16 bg-primary-100">
              {video.youtubeId ? (
                <iframe
                  class="h-full w-full"
                  src={`https://www.youtube.com/embed/${video.youtubeId}`}
                  title={video.titulo}
                  loading="lazy"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                  allowfullscreen
                ></iframe>
              ) : (
                <div class="flex h-full w-full items-center justify-center px-6 text-center">
                  <span class="rounded-lg border border-primary-200 bg-white/80 px-4 py-3 text-sm font-semibold text-primary-700">
                    Agrega aqui el ID de YouTube
                  </span>
                </div>
              )}
            </div>

            <div class="p-5 text-center">
              <h3 class="font-heading text-lg font-bold text-primary-700">
                {video.titulo}
              </h3>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>
