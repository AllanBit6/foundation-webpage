---
import Layout from "../layouts/Layout.astro";
import SectionHero from "../components/SectionHero.astro";
---

<Layout>
  <SectionHero
    title="Tourism with Purpose"
    image="https://rotaryatitlan.org/wp-content/uploads/2025/02/Captura-de-Pantalla-2025-02-04-a-las-15.57.38.png"
  >
    Experience Guatemala beyond tourism. Spend one meaningful week with
    Transforming Lives Foundation, combining cultural immersion,
    community service, and unforgettable travel experiences while making
    a direct impact in rural communities.

    <div class="mt-6">
      <a
        href="#coming-soon"
        class="inline-flex items-center rounded-lg bg-white px-6 py-3 font-semibold text-primary-700 shadow-sm hover:bg-gray-100"
      >
        Explore the Experience
      </a>
    </div>
  </SectionHero>

  <!-- Itinerary -->
<section class="bg-white py-16">
  <div class="mx-auto max-w-6xl px-4">
    <h2 class="mb-4 text-center text-3xl font-bold text-primary-700">
      7-Day Volunteer Travel Itinerary
    </h2>

    <p class="mx-auto mb-10 max-w-3xl text-center text-primary-600">
      A meaningful week designed to connect you with Guatemala’s culture,
      community, and purpose through service and unforgettable experiences.
    </p>

    <div class="overflow-hidden rounded-2xl border border-primary-100 shadow-md">
      <div class="overflow-x-auto">
        <table class="w-full text-left">

          <!-- Header -->
          <thead class="bg-primary-700 text-white">
            <tr>
              <th class="px-6 py-4 text-sm font-semibold uppercase tracking-wide">
                Day
              </th>
              <th class="px-6 py-4 text-sm font-semibold uppercase tracking-wide">
                Experience
              </th>
            </tr>
          </thead>

          <!-- Body -->
          <tbody class="divide-y divide-primary-100 text-primary-700">

            <tr class="bg-white transition hover:bg-primary-50">
              <td class="px-6 py-5 font-semibold whitespace-nowrap">
                Saturday
              </td>
              <td class="px-6 py-5 text-primary-600">
                Arrival at La Aurora International Airport in Guatemala City.
                Private transportation to our facilities in Totonicapán.
              </td>
            </tr>

            <tr class="bg-primary-50/50 transition hover:bg-primary-50">
              <td class="px-6 py-5 font-semibold whitespace-nowrap">
                Sunday
              </td>
              <td class="px-6 py-5 text-primary-600">
                Participate in a local worship service and cultural immersion
                with our community.
              </td>
            </tr>

            <tr class="bg-white transition hover:bg-primary-50">
              <td class="px-6 py-5 font-semibold whitespace-nowrap">
                Monday
              </td>
              <td class="px-6 py-5 text-primary-600">
                Volunteer activities focused on education and community
                development.
              </td>
            </tr>

            <tr class="bg-primary-50/50 transition hover:bg-primary-50">
              <td class="px-6 py-5 font-semibold whitespace-nowrap">
                Tuesday
              </td>
              <td class="px-6 py-5 text-primary-600">
                Continued hands-on service projects and local engagement.
              </td>
            </tr>

            <tr class="bg-white transition hover:bg-primary-50">
              <td class="px-6 py-5 font-semibold whitespace-nowrap">
                Wednesday
              </td>
              <td class="px-6 py-5 text-primary-600">
                Educational workshops and collaborative volunteer work.
              </td>
            </tr>

            <tr class="bg-primary-50/50 transition hover:bg-primary-50">
              <td class="px-6 py-5 font-semibold whitespace-nowrap">
                Thursday
              </td>
              <td class="px-6 py-5 text-primary-600">
                Suggested excursion to Panajachel and beautiful Lake Atitlán.
              </td>
            </tr>

            <tr class="bg-white transition hover:bg-primary-50">
              <td class="px-6 py-5 font-semibold whitespace-nowrap">
                Friday
              </td>
              <td class="px-6 py-5 text-primary-600">
                Suggested trip to Fuentes Georginas and Aguas Amargas.
              </td>
            </tr>

            <tr class="bg-primary-50/50 transition hover:bg-primary-50">
              <td class="px-6 py-5 font-semibold whitespace-nowrap">
                Saturday
              </td>
              <td class="px-6 py-5 text-primary-600">
                Transportation back to the airport for your departure.
              </td>
            </tr>

          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

  <!-- Destination Gallery -->
  <section class="bg-primary-50 py-16">
    <div class="mx-auto max-w-7xl px-4">
      <h2 class="mb-10 text-center text-3xl font-bold text-primary-700">
        Suggested Destinations During Your Stay
      </h2>

      <div class="grid gap-6 md:grid-cols-3">

        <div class="overflow-hidden rounded-xl bg-white shadow">
          <img src="https://www.guatemala.com/fotos/201805/Xocomil-885x500.jpg" class="h-56 w-full object-cover" />
          <div class="p-5">
            <h3 class="font-semibold text-primary-700">
              Xocomil – Retalhuleu
            </h3>
            <p class="text-sm text-primary-600">
              Approx. 3.5 hours from Totonicapán
            </p>
          </div>
        </div>

        <div class="overflow-hidden rounded-xl bg-white shadow">
          <img src="https://tse3.mm.bing.net/th/id/OIP.COEayPKwNlorzOPqtvKayAHaEx?rs=1&pid=ImgDetMain&o=7&rm=3" class="h-56 w-full object-cover" />
          <div class="p-5">
            <h3 class="font-semibold text-primary-700">
              Ahuehuetl Camps – Huehuetenango
            </h3>
            <p class="text-sm text-primary-600">
              Approx. 2.5 hours from Totonicapan
            </p>
          </div>
        </div>

        <div class="overflow-hidden rounded-xl bg-white shadow">
          <img src="https://tse1.mm.bing.net/th/id/OIP.2_aYjVSO-dycZ7DgRVxEIgHaEK?w=1920&h=1080&rs=1&pid=ImgDetMain&o=7&rm=3" class="h-56 w-full object-cover" />
          <div class="p-5">
            <h3 class="font-semibold text-primary-700">
              Panajachel – Sololá
            </h3>
            <p class="text-sm text-primary-600">
              Approx. 1.5 hours from Totonicapan
            </p>
          </div>
        </div>

        <div class="overflow-hidden rounded-xl bg-white shadow">
          <img src="https://www.guatemala.com/fotos/201703/Fuentes-Georginas1.jpg" class="h-56 w-full object-cover" />
          <div class="p-5">
            <h3 class="font-semibold text-primary-700">
              Fuentes Georginas
            </h3>
            <p class="text-sm text-primary-600">
              Approx. 1.5 hours from Totonicapan
            </p>
          </div>
        </div>

        <div class="overflow-hidden rounded-xl bg-white shadow">
          <img src="https://www.guatemala.com/fotos/2022/06/Zunil.jpg" class="h-56 w-full object-cover" />
          <div class="p-5">
            <h3 class="font-semibold text-primary-700">
              Aguas Amargas
            </h3>
            <p class="text-sm text-primary-600">
              Approx. 1.5 hours from Totonicapan
            </p>
          </div>
        </div>

        <div class="overflow-hidden rounded-xl bg-white shadow">
          <img src="https://tse3.mm.bing.net/th/id/OIP.5M3NIsvgXMrLK7nhGxfb-QHaFE?rs=1&pid=ImgDetMain&o=7&rm=3" class="h-56 w-full object-cover" />
          <div class="p-5">
            <h3 class="font-semibold text-primary-700">
              Volcán Santiaguito / Santa María
            </h3>
            <p class="text-sm text-primary-600">
              Approx. 1.5 hours from Totonicapan
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="bg-white py-16">
    <div class="mx-auto max-w-3xl px-4 text-center">
      <div class="rounded-2xl border border-primary-200 p-10 shadow-md">
        <h2 class="text-3xl font-bold text-primary-700">
          Preliminary Price
        </h2>

        <p class="mt-4 text-5xl font-extrabold text-primary-600">
          $800
        </p>

        <ul class="mt-6 space-y-2 text-primary-600">
          <li>✓ 3 meals per day</li>
          <li>✓ Airport transportation</li>
          <li>✓ Accommodation</li>
          <li>✓ Private bathroom access</li>
          <li>✓ Meeting & conference spaces</li>
          <li>✓ Volunteer coordination</li>
          <li class ="text-red-500">X Does not include airplane tickets</li>
        </ul>

        <div id="coming-soon" class="mt-8">
          <button
            disabled
            class="rounded-lg bg-primary-700 px-8 py-3 font-semibold text-white opacity-70 cursor-not-allowed"
          >
            Coming Soon
          </button>
        </div>
      </div>
    </div>
  </section>
</Layout>