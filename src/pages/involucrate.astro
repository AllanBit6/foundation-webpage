---
import Layout from "../layouts/Layout.astro";
import SectionHero from "../components/SectionHero.astro";
---

<Layout>
  <SectionHero title="Apoya Nuestra Misión con tu Donación" image="/public/images/involucrate.jpg">
      Tu generosidad puede transformar vidas. Dona hoy y ayuda a jóvenes de áreas rurales en Guatemala a acceder a educación, salud y oportunidades económicas. O accede y forma parte de nuestros programas de emprendimiento, salud y medio ambiente

      <div class="mt-6">
      <a href="#" class="inline-flex items-center rounded-lg bg-white px-6 py-3 font-semibold text-primary-700 shadow-sm hover:bg-gray-100">
        Llenar Formulario de Donación
      </a>
    </div>
  </SectionHero>
    

  <section class="bg-white py-12">
    <div class="mx-auto max-w-7xl px-4">
      <h2 class="mb-8 text-center text-2xl font-bold text-primary-700">
        Explora Más Sobre Nuestra Fundación
      </h2>
      <div class="grid gap-4 text-center md:grid-cols-5">
        <a href="/aplicacion" class="rounded-lg border border-primary-200 p-4 hover:bg-primary-50">
          <h3 class="font-semibold text-primary-700">Aplicar a Beca</h3>
          <p class="text-sm text-primary-600">Accede a oportunidades educativas</p>
        </a>
        <a href="/carreras" class="rounded-lg border border-primary-200 p-4 hover:bg-primary-50">
          <h3 class="font-semibold text-primary-700">Carreras</h3>
          <p class="text-sm text-primary-600">Únete a nuestro equipo</p>
        </a>
        <a href="/logros" class="rounded-lg border border-primary-200 p-4 hover:bg-primary-50">
          <h3 class="font-semibold text-primary-700">Logros</h3>
          <p class="text-sm text-primary-600">Conoce nuestros impactos</p>
        </a>
        <a href="/nosotros" class="rounded-lg border border-primary-200 p-4 hover:bg-primary-50">
          <h3 class="font-semibold text-primary-700">Nosotros</h3>
          <p class="text-sm text-primary-600">Nuestra historia y valores</p>
        </a>
        <a href="/programas" class="rounded-lg border border-primary-200 p-4 hover:bg-primary-50">
          <h3 class="font-semibold text-primary-700">Programas</h3>
          <p class="text-sm text-primary-600">Descubre nuestras iniciativas</p>
        </a>
      </div>
    </div>
  </section>
</Layout>