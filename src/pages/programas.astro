---
import Layout from '../layouts/Layout.astro';
import SectionHero from '../components/SectionHero.astro';

const programas = [
  {
    titulo: "Apadrinamiento Educativo",
    categoria: "Educacion",
    descripcion:
      "Este programa tiene como objetivo financiar la educación primaria, nivel básico y carreras de niños y jóvenes en pobreza procedentes del área rural y zonas marginales del área urbana. Apadrinamiento anual por estudiante Q. 2,100.00   Apadrinamiento mensual por estudiante Q. 175.00",
    imagen:
      "/images/apadrinar.jpg",
    cta: "Conocer mas",
  },
  {
    titulo: "Donativos para insumos médicos",
    categoria: "Salud",
    descripcion:
      "Facilitamos recursos médicos esenciales para comunidades con acceso limitado a servicios de salud. Si deseas ser voluntario en este programa, favor haz clic aquí para dejar tus datos y con gusto nos comunicaremos contigo.  \nSi deseas hablar con nosotros favor llamar al (502) 2435-3794",
    imagen:
      "/images/health.jpg",
    cta: "Donar ahora",
  },
  {
    titulo: "Inversion social para emprendedores",
    categoria: "Desarrollo económico",
    descripcion:
      "Queremos desafiarte para ser parte de nuestro grupo selecto de inversionistas sociales, invirtiendo o ahorrando en nuestro programa, con su inversión recibirá un retorno anual muy por encima del mercado financiero y ayudara a financiar cientos de emprendedores del área rural, con  la misión de aliviar la pobreza rural y construir una nación más justa y equitativa. Llama al  (502) 2435-3794   o    info@coopymer.com",
    imagen:
      "/images/inversion.png",
    cta: "Invertir",
  },
  {
    titulo: "Proyectos ambientales",
    categoria: "Sostenibilidad",
    descripcion:
      "Te invitamos a unirte a nuestro programa de RESCATE por la naturaleza, donando $1.00 por cada árbol sembrado en áreas protegidas en las aldeas rurales.  Haz click para llenar formulario.",
    imagen:
      "/images/arboles.webp",
    cta: "Participar",
  },
];

const enfoque = [
  "Diagnóstico de necesidades",
  "Acompañamiento cercano",
  "Alianzas con instituciones",
  "Medición de impacto",
];
---

<Layout>
  <SectionHero title="Programas" video = "https://res.cloudinary.com/dnhistzl2/video/upload/q_auto/f_auto/v1778692164/programs_dxxrek.mp4">
    Generamos oportunidades reales a traves de educación, salud y desarrollo sostenible.
  </SectionHero>

 <section class="animate lift bg-secondary-soft">
  <div class="mx-auto max-w-7xl px-4 py-14 lg:py-20">

    <div class="animate fade-up mx-auto mb-14 max-w-3xl text-center">
      <span class="animate pop-strong text-sm font-bold uppercase tracking-[0.25em] text-primary-600">
        Áreas de impacto
      </span>

      <h2 class="animate lift mt-3 text-3xl font-extrabold text-primary-700 sm:text-4xl">
        Programas que transforman vidas
      </h2>

      <p class="animate fade-up mt-4 text-primary-800 leading-7">
        Cada programa responde a una necesidad distinta, pero todos trabajan hacia el mismo objetivo: desarrollo sostenible en Guatemala.
      </p>
    </div>

    <div class="space-y-10">

      <article class="grid overflow-hidden rounded-3xl bg-white shadow-lg ring-1 ring-black/5 md:grid-cols-2">

        <div class="h-72 md:h-full overflow-hidden">
          <img
            src={programas[0].imagen}
            class="animate zoom-fade h-full w-full object-cover"
          />
        </div>

        <div class="p-8 flex flex-col justify-center">
          <span class="animate zoom-fade text-xs font-bold uppercase tracking-[0.25em] text-primary-500">
            {programas[0].categoria}
          </span>

          <h3 class="animate zoom-fade mt-2 text-3xl font-bold text-primary-700">
            {programas[0].titulo}
          </h3>

          <p class="mt-4 text-primary-800 leading-7">
            {programas[0].descripcion}
          </p>

          <a href="/involucrate" class="animate fade-up mt-6 inline-flex w-fit rounded-lg bg-primary-700 px-5 py-2.5 text-white font-semibold hover:bg-primary-800">
            {programas[0].cta}
          </a>
        </div>
      </article>

      <div class="grid gap-8 md:grid-cols-2">

        {programas.slice(1).map((programa) => (
          <article class="group overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-black/5 transition hover:-translate-y-1 hover:shadow-lg">

            <div class="animate fade-up h-52 overflow-hidden">
              <img
                src={programa.imagen}
                class="h-full w-full object-cover transition group-hover:scale-105"
              />
            </div>

            <div class="p-6">
              <span class="animate fade-up text-xs font-bold uppercase tracking-[0.25em] text-primary-500">
                {programa.categoria}
              </span>

              <h3 class="animate fade-up mt-2 text-xl font-bold text-primary-700">
                {programa.titulo}
              </h3>

              <p class="animate fade-up mt-3 text-primary-800 leading-7 text-sm">
                {programa.descripcion}
              </p>

              <a href="/involucrate" class="animate fade-up mt-4 inline-flex text-primary-700 font-semibold hover:underline">
                {programa.cta} →
              </a>
            </div>
          </article>
        ))}

      </div>
    </div>
  </div>
</section>

  <section class=" bg-white">
    <div class="animate lift mx-auto grid max-w-7xl gap-10 px-4 py-12 sm:px-6 lg:grid-cols-[1fr_1.2fr] lg:px-8 lg:py-16">
      <div>
        <span class="text-sm font-bold uppercase tracking-wide text-primary-600">
          Como trabajamos
        </span>
        <h2 class="animate fade-up mt-3 font-heading text-3xl font-extrabold text-primary-700 sm:text-4xl">
          Un proceso claro para generar impacto
        </h2>
        <p class="animate fade-up mt-4 leading-7 text-primary-800">
          Nuestro equipo acompaña cada iniciativa desde la identificacion de necesidades hasta el seguimiento de resultados.
        </p>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        {enfoque.map((item, index) => (
          <div class="rounded-lg border border-secondary/60 bg-secondary-soft p-6">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-primary-700 text-sm font-extrabold text-white">
              {index + 1}
            </div>
            <h3 class="font-heading text-lg font-bold text-primary-700">
              {item}
            </h3>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="animate pop bg-primary-700">
    <div class="mx-auto max-w-7xl px-4 py-12 text-center sm:px-6 lg:px-8">
      <h2 class="font-heading text-3xl font-extrabold text-white">
        Construyamos mas oportunidades
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-primary-50">
        Tu apoyo puede fortalecer nuestros programas y ampliar su alcance en comunidades de Guatemala.
      </p>
      <a
        href="#"
        class="mt-6 inline-flex rounded-lg bg-white px-6 py-3 font-semibold text-primary-700 transition hover:bg-primary-50 focus:outline-none focus:ring-4 focus:ring-primary-300"
      >
        Súmate al programa
      </a>
    </div>
  </section>
</Layout>
