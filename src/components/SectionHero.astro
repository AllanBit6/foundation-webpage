---
const { title, video, image } = Astro.props;
const hasMedia = Boolean(video || image);
---

<section class={`section-hero relative flex min-h-[70svh] items-center overflow-hidden ${hasMedia ? 'bg-primary-900' : 'bg-primary-700'}`}>

  {video && (
    <video 
      class="absolute inset-0 h-full w-full object-cover"
      src={video}
      autoplay
      muted
      loop
      playsinline
    ></video>
  )}

  {!video && image && (
    <img
      class="absolute inset-0 h-full w-full object-cover"
      src={image}
      alt=""
      loading="eager"
    />
  )}

  <div class={`absolute inset-0 ${hasMedia ? 'bg-primary-950/55' : 'bg-primary-800'}`}></div>

  <div class="animate-zoomFade relative mx-auto max-w-7xl px-4 text-center">
    <h1 class="mb-4 font-heading text-4xl font-extrabold text-white md:text-5xl lg:text-6xl">
      {title}
    </h1>

    <p class="mx-auto max-w-2xl text-lg text-white">
      <slot />
    </p>
  </div>

</section>
