---
const { title, video } = Astro.props;
---

<section class={`section-hero relative flex min-h-[70vh] items-center overflow-hidden ${video ? 'bg-primary-900' : 'bg-primary-700'}`}>

  {video && (
    <video 
      class="absolute inset-0 h-full w-full object-cover"
      src={video}
      autoplay
      muted
      loop
      playsinline
    ></video>
  )}

  <div class={`absolute inset-0 ${video ? 'bg-primary-950/55' : 'bg-primary-800'}`}></div>

  <div class="relative mx-auto max-w-7xl px-4 text-center">
    <h1 class="mb-4 font-heading text-4xl font-extrabold text-white md:text-5xl lg:text-6xl">
      {title}
    </h1>

    <p class="mx-auto max-w-2xl text-lg text-white">
      <slot />
    </p>
  </div>

</section>
