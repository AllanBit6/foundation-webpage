---
const { pathname } = Astro.url;

const isActive = (path:any) =>
  pathname === path || pathname.startsWith(path + "/");
---

<header class="fixed top-0 left-0 z-50 w-full">
  <nav class="bg-white/95 border-b border-secondary/60 px-5 py-4 shadow-sm backdrop-blur lg:px-6">
    <div class="mx-auto flex max-w-7xl flex-wrap items-center justify-between">

      <a href="/" class="flex items-center">
        <img src="/logo.jpg" class="mr-3 h-8 sm:h-10 lg:h-14" alt="Logo" />
      </a>

      <div class="flex items-center lg:order-2">
        <div class="hidden lg:flex">
          <a
            href="/aplicacion"
            class={`mr-2 rounded-lg px-4 py-2 text-sm font-semibold shadow-sm transition ${
              isActive("/aplicacion")
                ? "bg-primary-800 text-white"
                : "bg-primary-700 text-white hover:bg-primary-800"
            }`}
          >
            Aplicar a una beca
          </a>

          <a
            href="/involucrate"
            class={`rounded-lg border px-4 py-2 text-sm font-semibold transition ${
              isActive("/involucrate")
                ? "bg-primary-100 text-primary-900 border-primary-400"
                : "border-primary-300 bg-secondary-soft text-primary-800 hover:bg-primary-100"
            }`}
          >
            Quiero apoyar
          </a>
        </div>

        <button
          id="menu-btn"
          class="ml-1 inline-flex items-center rounded-lg p-2 text-primary-700 hover:bg-primary-50 lg:hidden"
          aria-label="Abrir menu"
        >
          <span class="text-2xl leading-none">&#9776;</span>
        </button>
      </div>

      <!-- DESKTOP MENU -->
      <div class="hidden w-full lg:order-1 lg:flex lg:w-auto">
        <ul class="mt-4 flex flex-col font-semibold lg:mt-0 lg:flex-row lg:space-x-8">

          <li>
            <a
              href="/"
              class={`block py-2 transition ${
                isActive("/")
                  ? "text-primary-900 font-bold"
                  : "text-primary-700 hover:text-primary-900"
              }`}
            >
              Inicio
            </a>
          </li>

          <li>
            <a
              href="/aplicacion"
              class={`block py-2 transition ${
                isActive("/aplicacion")
                  ? "text-primary-900 font-bold"
                  : "text-primary-700 hover:text-primary-900"
              }`}
            >
              Proceso
            </a>
          </li>

          <li>
            <a
              href="/carreras"
              class={`block py-2 transition ${
                isActive("/carreras")
                  ? "text-primary-900 font-bold"
                  : "text-primary-700 hover:text-primary-900"
              }`}
            >
              Carreras
            </a>
          </li>

          <li>
            <a
              href="/nosotros"
              class={`block py-2 transition ${
                isActive("/nosotros")
                  ? "text-primary-900 font-bold"
                  : "text-primary-700 hover:text-primary-900"
              }`}
            >
              Nosotros
            </a>
          </li>

          <li>
            <a
              href="/programas"
              class={`block py-2 transition ${
                isActive("/programas")
                  ? "text-primary-900 font-bold"
                  : "text-primary-700 hover:text-primary-900"
              }`}
            >
              Programas
            </a>
          </li>

          <li>
            <a
              href="/logros"
              class={`block py-2 transition ${
                isActive("/logros")
                  ? "text-primary-900 font-bold"
                  : "text-primary-700 hover:text-primary-900"
              }`}
            >
              Logros
            </a>
          </li>

          <li>
            <a
              href="/involucrate"
              class={`block py-2 transition ${
                isActive("/involucrate")
                  ? "text-primary-900 font-bold"
                  : "text-primary-700 hover:text-primary-900"
              }`}
            >
              Involucrate
            </a>
          </li>

        </ul>
      </div>

    </div>
  </nav>

  <!-- MOBILE -->
  <div
  id="mobile-menu"
  class="max-h-0 overflow-hidden border-t border-secondary/60 bg-white shadow-sm opacity-0 -translate-y-2 pointer-events-none transition-all duration-300 ease-out lg:hidden"
>
    <ul class="flex flex-col gap-8 px-4 py-4 font-semibold text-primary-800">

      <li><a href="/" class={isActive("/") ? "text-primary-900 font-bold" : ""}>Inicio</a></li>
      <li><a href="/aplicacion" class={isActive("/aplicacion") ? "text-primary-900 font-bold" : ""}>Proceso de aplicacion</a></li>
      <li><a href="/carreras" class={isActive("/carreras") ? "text-primary-900 font-bold" : ""}>Carreras</a></li>
      <li><a href="/nosotros" class={isActive("/nosotros") ? "text-primary-900 font-bold" : ""}>Nosotros</a></li>
      <li><a href="/programas" class={isActive("/programas") ? "text-primary-900 font-bold" : ""}>Programas</a></li>
      <li><a href="/logros" class={isActive("/logros") ? "text-primary-900 font-bold" : ""}>Logros</a></li>
      <li><a href="/involucrate" class={isActive("/involucrate") ? "text-primary-900 font-bold" : ""}>Involucrate</a></li>

    </ul>
  </div>
</header>