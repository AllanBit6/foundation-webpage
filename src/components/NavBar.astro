---
const { pathname } = Astro.url;

const isActive = (path: any) =>
  pathname === path || pathname.startsWith(path + "/");
---

<header class="fixed top-0 left-0 z-50 w-full">
  <nav class="border-b border-secondary/60 bg-white/95 px-5 py-4 shadow-sm backdrop-blur lg:px-6">
    <div class="mx-auto flex max-w-7xl items-center justify-between">

      <!-- Logo -->
      <a href="/" class="flex items-center">
        <img src="/logo.jpg" class="mr-3 h-8 sm:h-10 lg:h-14" alt="Logo" />
      </a>

      <!-- Desktop Menu -->
      <div class="hidden lg:flex lg:flex-1 lg:justify-center">
        <ul class="flex items-center space-x-8 font-semibold">

          <li>
            <a
              href="/"
              class={`transition ${
                isActive("/")
                  ? "font-bold text-primary-900"
                  : "text-primary-700 hover:text-primary-900"
              }`}
            >
              Inicio
            </a>
          </li>

          <li>
            <a
              href="/nosotros"
              class={`transition ${
                isActive("/nosotros")
                  ? "font-bold text-primary-900"
                  : "text-primary-700 hover:text-primary-900"
              }`}
            >
              Nosotros
            </a>
          </li>

          <li>
            <a
              href="/programas"
              class={`transition ${
                isActive("/programas")
                  ? "font-bold text-primary-900"
                  : "text-primary-700 hover:text-primary-900"
              }`}
            >
              Programas
            </a>
          </li>

          <li>
            <a
              href="/logros"
              class={`transition ${
                isActive("/logros")
                  ? "font-bold text-primary-900"
                  : "text-primary-700 hover:text-primary-900"
              }`}
            >
              Logros
            </a>
          </li>

          <li>
            <a
              href="/carreras"
              class={`transition ${
                isActive("/carreras")
                  ? "font-bold text-primary-900"
                  : "text-primary-700 hover:text-primary-900"
              }`}
            >
              Carreras
            </a>
          </li>

        </ul>
      </div>

      <!-- CTA Buttons -->
      <div class="hidden items-center gap-2 lg:flex">

        <a
          href="/aplicacion"
          class={`rounded-lg px-4 py-2 text-sm font-semibold shadow-sm transition ${
            isActive("/aplicacion")
              ? "bg-primary-800 text-white"
              : "bg-primary-700 text-white hover:bg-primary-800"
          }`}
        >
          Aplicar a una beca
        </a>

        <a
          href="/tourism-with-purpose"
          class={`rounded-lg px-4 py-2 text-sm font-semibold shadow-sm transition ${
            isActive("/tourism-with-purpose")
              ? "bg-amber-500 text-white"
              : "bg-amber-400 text-primary-900 hover:bg-amber-500"
          }`}
        >
        Tourism with Purpose
        </a>

        <a
          href="/involucrate"
          class={`rounded-lg border px-4 py-2 text-sm font-semibold transition ${
            isActive("/involucrate")
              ? "border-primary-400 bg-primary-100 text-primary-900"
              : "border-primary-300 bg-secondary-soft text-primary-800 hover:bg-primary-100"
          }`}
        >
          Quiero apoyar
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="menu-btn"
        class="ml-1 inline-flex items-center rounded-lg p-2 text-primary-700 hover:bg-primary-50 lg:hidden"
        aria-label="Abrir menu"
      >
        <span class="text-2xl leading-none">&#9776;</span>
      </button>

    </div>
  </nav>

  <!-- MOBILE MENU -->
  <div
  id="mobile-menu"
  class="pointer-events-none max-h-0 -translate-y-2 overflow-hidden border-t border-secondary/60 bg-white opacity-0 shadow-sm transition-all duration-300 ease-out lg:hidden"
>
  <ul class="mx-auto flex max-w-md flex-col gap-8 px-6 py-6 text-lg font-semibold text-primary-800">

    <li>
      <a href="/" class={isActive("/") ? "font-bold text-primary-900" : ""}>
        Inicio
      </a>
    </li>

    <li>
      <a href="/nosotros" class={isActive("/nosotros") ? "font-bold text-primary-900" : ""}>
        Nosotros
      </a>
    </li>

    <li>
      <a href="/programas" class={isActive("/programas") ? "font-bold text-primary-900" : ""}>
        Programas
      </a>
    </li>

    <li>
      <a href="/logros" class={isActive("/logros") ? "font-bold text-primary-900" : ""}>
        Logros
      </a>
    </li>

    <li>
      <a href="/carreras" class={isActive("/carreras") ? "font-bold text-primary-900" : ""}>
        Carreras
      </a>
    </li>

    <hr class="border-primary-200" />

    <li>
      <a
        href="/aplicacion"
        class="block rounded-lg bg-primary-700 px-4 py-3 text-center text-base text-white shadow-sm"
      >
        Aplicar a una beca
      </a>
    </li>

    <li>
      <a
        href="/tourism-with-purpose"
        class="block rounded-lg bg-amber-400 px-4 py-3 text-center text-base font-bold text-primary-900 shadow-sm"
      >
      Tourism with Purpose
      </a>
    </li>

    <li>
      <a
        href="/involucrate"
        class="block rounded-lg border border-primary-300 px-4 py-3 text-center text-base"
      >
        Quiero apoyar
      </a>
    </li>

  </ul>
</div>
</header>